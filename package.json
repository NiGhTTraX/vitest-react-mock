{
  "name": "vitest-react-mock",
  "version": "2.1.0",
  "description": "vitest helper for react-mock-component",
  "keywords": [
    "vitest",
    "react",
    "mock",
    "tdd",
    "testing",
    "expect"
  ],
  "author": "Andrei Picus",
  "license": "MIT",
  "homepage": "https://github.com/NiGhTTraX/vitest-react-mock",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean --tsconfig tsconfig.build.json --attw --publint",
    "check-types": "attw --pack .",
    "prepublishOnly": "pnpm run build",
    "release": "standard-version",
    "lint": "eslint .",
    "pretest": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest --coverage"
  },
  "dependencies": {
    "@vitest/expect": "~4.1.0",
    "expect": "~30.4.0",
    "jest-matcher-utils": "~30.4.0"
  },
  "peerDependencies": {
    "react-mock-component": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "vitest": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "~0.18.0",
    "@nighttrax/eslint-config-ts": "~12.2.0",
    "@testing-library/dom": "~10.4.1",
    "@testing-library/react": "~16.3.0",
    "@types/react": "~19.2.0",
    "@vitejs/plugin-react": "~6.0.1",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "~10.4.0",
    "jsdom": "~29.1.0",
    "prettier": "~3.8.0",
    "publint": "~0.3.19",
    "react": "~19.2.0",
    "react-dom": "~19.2.0",
    "react-mock-component": "~5.0.0",
    "standard-version": "~9.5.0",
    "strip-ansi": "~7.2.0",
    "tsdown": "~0.22.0",
    "typescript": "~6.0.0",
    "vite": "~8.0.3",
    "vitest": "~4.1.0"
  },
  "packageManager": "pnpm@11.3.0"
}
