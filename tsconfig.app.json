{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",

    "target": "ES6",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "types": [],
    "lib": ["ES6", "DOM"],
    "skipLibCheck": true,

    "strict": true,
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["src"]
}
